# Iwexa Hub API Configuration
IWEXA_API_BASE_URL=https://api.iwexa.com
IWEXA_API_KEY=
IWEXA_HMAC_SECRET=

# Sync Job Configuration
IWEXA_SYNC_JOB_RETRY_LIMIT=3
